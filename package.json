{
  "name": "justforlaughs",
  "displayName": "Just For Laughs",
  "publisher": "JayantNavrange",
  "description": "Memes when you need",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "author": {
    "name": "Jayant Navrange",
    "email": "jayantur13@gmail.com",
    "url": "https://www.linkedin.com/in/jayant-navrange-238aa5138/"
  },
  "license": "MIT",
  "icon": "images/logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayantur13/just-for-laughs-vsc-extension.git"
  },
  "homepage": "https://github.com/jayantur13/just-for-laughs-vsc-extension#readme",
  "bugs": {
    "url": "https://github.com/jayantur13/just-for-laughs-vsc-extension/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/jayantur13"
  },
  "keywords": [
    "vscode-extension",
    "extension",
    "vsc-extension",
    "memes",
    "jokes",
    "humor"
  ],
  "preview": false,
  "galleryBanner": {
    "color": "#41205f",
    "theme": "dark"
  },
  "categories": [
    "Other"
  ],
  "main": "main/extension.js",
  "contributes": {
    "configuration": {
      "title": "Just For Laughs",
      "properties": {
        "justforlaughs.ext.subreddit": {
          "type": "string",
          "default": "memes",
          "markdownDescription": "Subreddit to fetch memes from."
        },
        "justforlaughs.ext.count": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 50,
          "markdownDescription": "Number of memes to fetch."
        }
      }
    },
    "commands": [
      {
        "command": "justforlaughs.ext.getmeme",
        "title": "Just For Laughs: Get Meme"
      },
      {
        "command": "justforlaughs.ext.getsettings",
        "title": "Just For Laughs: Show Settings"
      },
      {
        "command": "justforlaughs.ext.changesubreddit",
        "title": "Just For Laughs: Change Subreddit"
      },
      {
        "command": "justforlaughs.ext.changecount",
        "title": "Just For Laughs: Change Meme Count"
      }
    ],
    "keybindings": [
      {
        "command": "justforlaughs.ext.getmeme",
        "key": "Ctrl+P",
        "win": "Ctrl+P",
        "mac": "Ctrl+P"
      }
    ]
  },
  "scripts": {
    "test": "node ./test/runTest.js",
    "test-coverage": "nyc --reporter=html --reporter=text mocha"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "@vscode/test-electron": "^3.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "axios": "^1.17.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "diff": "^8.0.3"
  }
}
